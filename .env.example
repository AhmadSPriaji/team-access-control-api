# Database Configuration (Match with docker-compose.yml if using Docker)
DATABASE_URL="postgresql://admin:ahmadsiddiq@localhost:5432/team_access_db?schema=public"

# Redis Configuration (For Rate Limiting & Caching)
REDIS_URL="redis://localhost:6379"

# Application Port
PORT=3000

# JWT Secrets for Authentication
JWT_SECRET="super-secret-key-untuk-akses-token"
JWT_REFRESH_SECRET="super-secret-key-untuk-refresh-token"

# SMTP Configuration for Email Service (e.g., Mailtrap, SendGrid, etc)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-pass"
